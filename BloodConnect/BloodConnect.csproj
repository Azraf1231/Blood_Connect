<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>BloodConnect</RootNamespace>
    <AssemblyName>BloodConnect</AssemblyName>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <ApplicationHighDpiMode>SystemAware</ApplicationHighDpiMode>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SqlClient" Version="6.0.2" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="UI\Receiver\ReceiverDashboardHomeForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="UI\Receiver\ReceiverDashboardHomeForm.Designer.cs">
      <DependentUpon>ReceiverDashboardHomeForm.cs</DependentUpon>
    </Compile>
  </ItemGroup>

</Project>
